# AMD Developer Cloud
AMD_CLOUD_API_KEY=your_amd_cloud_key_here
AMD_CLOUD_ENDPOINT=https://api.amd.com/v1/inference
AMD_CLOUD_MODEL=deepseek-ai/DeepSeek-R1-Distill-Llama-70B

# Fallback / local vLLM
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_MODEL=deepseek-ai/DeepSeek-R1-Distill-Llama-70B

# Threat intel APIs
VIRUSTOTAL_API_KEY=your_vt_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Database
POSTGRES_URL=postgresql://sentinel:sentinel@localhost:5432/sentinelmesh
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinelmesh

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=sentinel.events.raw
KAFKA_TOPIC_CLASSIFIED=sentinel.events.classified
KAFKA_TOPIC_ALERTS=sentinel.alerts

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
